{
    "api": {
        "nombre": "PetMatch API",
        "version": "1.0.0",
        "descripcion": "API REST + WebSocket en tiempo real para la aplicación de adopción y acogida de mascotas PetMatch.",
        "baseUrl_local": "http://10.0.2.2:4000",
        "baseUrl_produccion": "https://tu-app.onrender.com",
        "notas_generales": [
            "Todos los endpoints REST devuelven JSON.",
            "En caso de error del servidor se devuelve status 500 con un mensaje de texto.",
            "Los campos 'createdAt' y 'updatedAt' son generados automáticamente por el servidor.",
            "Para el emulador de Android usar IP 10.0.2.2. Para dispositivo físico usar la IP local del PC (ej: 192.168.x.x)."
        ]
    },
    "websocket": {
        "descripcion": "El servidor usa Socket.io. Al conectarse, el cliente recibirá eventos automáticamente cada vez que alguien modifique datos en la base de datos, sin necesidad de hacer polling.",
        "url_conexion_local": "ws://10.0.2.2:4000",
        "url_conexion_produccion": "wss://tu-app.onrender.com",
        "dependencia_android": "io.socket:socket.io-client:2.1.0",
        "eventos": [
            {
                "nombre": "mascota_actualizada",
                "descripcion": "Se emite cuando se CREA o ACTUALIZA una mascota. El payload es el objeto completo de la mascota con todos sus campos actualizados.",
                "cuando_llega": "Después de POST /api/mascotas o PUT /api/mascotas/:id",
                "payload_ejemplo": {
                    "id": 1,
                    "nombre": "Max",
                    "especie": "Perro",
                    "edad": 3,
                    "estadoSalud": "Saludable",
                    "estado": "En acogida",
                    "hogarId": 2,
                    "fotoUrl": null,
                    "createdAt": "2025-02-21T20:00:00.000Z",
                    "updatedAt": "2025-02-21T20:05:00.000Z"
                },
                "accion_recomendada_android": "Hacer upsert de este objeto en la base de datos local Room. El Flow de Room actualizará la UI automáticamente."
            },
            {
                "nombre": "mascota_eliminada",
                "descripcion": "Se emite cuando se ELIMINA una mascota. El payload solo contiene el ID de la mascota eliminada.",
                "cuando_llega": "Después de DELETE /api/mascotas/:id",
                "payload_ejemplo": {
                    "id": 1
                },
                "accion_recomendada_android": "Eliminar de Room el registro con ese id. El Flow de Room actualizará la UI automáticamente."
            },
            {
                "nombre": "hogar_actualizado",
                "descripcion": "Se emite cuando se CREA o ACTUALIZA un hogar. El payload es el objeto completo del hogar.",
                "cuando_llega": "Después de POST /api/hogares o PUT /api/hogares/:id",
                "payload_ejemplo": {
                    "id": 1,
                    "nombreVoluntario": "Laura Pérez",
                    "direccion": "Calle 10 #45-32",
                    "telefono": "3001234567",
                    "capacidad": 3,
                    "tipoMascotaAceptada": "Perros",
                    "suministrosDisponibles": "Camas, comida, correas",
                    "ocupacionActual": 1,
                    "createdAt": "2025-02-21T18:00:00.000Z",
                    "updatedAt": "2025-02-21T20:05:00.000Z"
                },
                "accion_recomendada_android": "Hacer upsert de este objeto en la base de datos local Room."
            },
            {
                "nombre": "hogar_eliminado",
                "descripcion": "Se emite cuando se ELIMINA un hogar. El payload solo contiene el ID del hogar eliminado.",
                "cuando_llega": "Después de DELETE /api/hogares/:id",
                "payload_ejemplo": {
                    "id": 1
                },
                "accion_recomendada_android": "Eliminar de Room el registro con ese id."
            }
        ]
    },
    "endpoints": {
        "usuarios": {
            "descripcion": "Gestión de cuentas de usuario. Roles disponibles: 'admin' y 'voluntario'.",
            "base_path": "/api/usuarios",
            "operaciones": [
                {
                    "id": "registrar_usuario",
                    "descripcion": "Registra un nuevo usuario en el sistema. La contraseña se almacena de forma segura con hash bcrypt.",
                    "metodo": "POST",
                    "url": "/api/usuarios/registro",
                    "body_requerido": {
                        "nombre": "string — Nombre completo del usuario. REQUERIDO.",
                        "email": "string — Correo electrónico único y válido. REQUERIDO.",
                        "password": "string — Contraseña en texto plano (el servidor la encripta). REQUERIDO.",
                        "telefono": "string — Número de contacto. OPCIONAL.",
                        "rol": "string — 'admin' o 'voluntario'. Por defecto: 'voluntario'. OPCIONAL."
                    },
                    "body_ejemplo": {
                        "nombre": "Juan García",
                        "email": "juan@email.com",
                        "password": "miPassword123",
                        "telefono": "3009876543",
                        "rol": "voluntario"
                    },
                    "respuesta_exitosa": {
                        "status": 201,
                        "body_ejemplo": {
                            "id": 1,
                            "nombre": "Juan García",
                            "email": "juan@email.com",
                            "telefono": "3009876543",
                            "rol": "voluntario",
                            "createdAt": "2025-02-21T20:00:00.000Z",
                            "updatedAt": "2025-02-21T20:00:00.000Z"
                        }
                    },
                    "errores_posibles": {
                        "500": "Error del servidor (ej: email duplicado)."
                    },
                    "emite_evento_socket": false
                },
                {
                    "id": "login_usuario",
                    "descripcion": "Autentica un usuario y devuelve un token JWT para usar en futuras peticiones.",
                    "metodo": "POST",
                    "url": "/api/usuarios/login",
                    "body_requerido": {
                        "email": "string — Correo registrado. REQUERIDO.",
                        "password": "string — Contraseña en texto plano. REQUERIDO."
                    },
                    "body_ejemplo": {
                        "email": "juan@email.com",
                        "password": "miPassword123"
                    },
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": {
                            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                        }
                    },
                    "errores_posibles": {
                        "400": "Credenciales incorrectas.",
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": false
                }
            ]
        },
        "mascotas": {
            "descripcion": "Gestión completa de mascotas en adopción/acogida. Especie puede ser 'Perro', 'Gato' u 'Otro'. Estado puede ser 'Sin hogar' o 'En acogida'.",
            "base_path": "/api/mascotas",
            "operaciones": [
                {
                    "id": "crear_mascota",
                    "descripcion": "Registra una nueva mascota en el sistema. El estado inicial es automáticamente 'Sin hogar'.",
                    "metodo": "POST",
                    "url": "/api/mascotas",
                    "body_requerido": {
                        "nombre": "string — Nombre de la mascota. REQUERIDO.",
                        "especie": "string — 'Perro', 'Gato' u 'Otro'. REQUERIDO.",
                        "edad": "integer — Edad en años. REQUERIDO.",
                        "estadoSalud": "string — Descripción del estado de salud. Por defecto: 'Saludable'. REQUERIDO.",
                        "fotoUrl": "string — URL de la foto de la mascota. OPCIONAL."
                    },
                    "body_ejemplo": {
                        "nombre": "Max",
                        "especie": "Perro",
                        "edad": 3,
                        "estadoSalud": "Saludable",
                        "fotoUrl": "https://ejemplo.com/foto_max.jpg"
                    },
                    "respuesta_exitosa": {
                        "status": 201,
                        "body_ejemplo": {
                            "id": 1,
                            "nombre": "Max",
                            "especie": "Perro",
                            "edad": 3,
                            "estadoSalud": "Saludable",
                            "estado": "Sin hogar",
                            "hogarId": null,
                            "fotoUrl": "https://ejemplo.com/foto_max.jpg",
                            "createdAt": "2025-02-21T20:00:00.000Z",
                            "updatedAt": "2025-02-21T20:00:00.000Z"
                        }
                    },
                    "errores_posibles": {
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": true,
                    "evento_emitido": "mascota_actualizada"
                },
                {
                    "id": "obtener_mascotas",
                    "descripcion": "Devuelve la lista completa de todas las mascotas registradas.",
                    "metodo": "GET",
                    "url": "/api/mascotas",
                    "body_requerido": null,
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": [
                            {
                                "id": 1,
                                "nombre": "Max",
                                "especie": "Perro",
                                "edad": 3,
                                "estadoSalud": "Saludable",
                                "estado": "En acogida",
                                "hogarId": 2,
                                "fotoUrl": null,
                                "createdAt": "2025-02-21T20:00:00.000Z",
                                "updatedAt": "2025-02-21T20:00:00.000Z"
                            }
                        ]
                    },
                    "errores_posibles": {
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": false
                },
                {
                    "id": "obtener_mascota_por_id",
                    "descripcion": "Devuelve los datos de una sola mascota buscada por su ID.",
                    "metodo": "GET",
                    "url": "/api/mascotas/:id",
                    "parametros_url": {
                        "id": "integer — ID único de la mascota."
                    },
                    "body_requerido": null,
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": {
                            "id": 1,
                            "nombre": "Max",
                            "especie": "Perro",
                            "edad": 3,
                            "estadoSalud": "Saludable",
                            "estado": "Sin hogar",
                            "hogarId": null,
                            "fotoUrl": null,
                            "createdAt": "2025-02-21T20:00:00.000Z",
                            "updatedAt": "2025-02-21T20:00:00.000Z"
                        }
                    },
                    "errores_posibles": {
                        "404": "Mascota no encontrada.",
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": false
                },
                {
                    "id": "buscar_mascotas_por_hogar",
                    "descripcion": "Devuelve todas las mascotas que están asignadas a un hogar específico.",
                    "metodo": "GET",
                    "url": "/api/mascotas/hogar/:idHogar",
                    "parametros_url": {
                        "idHogar": "integer — ID del hogar del que se quieren ver las mascotas."
                    },
                    "body_requerido": null,
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": [
                            {
                                "id": 1,
                                "nombre": "Max",
                                "especie": "Perro",
                                "edad": 3,
                                "estadoSalud": "Saludable",
                                "estado": "En acogida",
                                "hogarId": 2,
                                "fotoUrl": null,
                                "createdAt": "2025-02-21T20:00:00.000Z",
                                "updatedAt": "2025-02-21T20:00:00.000Z"
                            }
                        ]
                    },
                    "errores_posibles": {
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": false
                },
                {
                    "id": "actualizar_mascota",
                    "descripcion": "Actualiza los datos de una mascota. También permite ASIGNAR o DESASIGNAR un hogar. IMPORTANTE: Si se envía 'hogarId' con un número entero, el sistema verifica la capacidad del hogar y asigna la mascota automáticamente cambiando su estado a 'En acogida'. Si se envía 'hogarId' como null o cadena vacía, se desasigna del hogar y el estado vuelve a 'Sin hogar'.",
                    "metodo": "PUT",
                    "url": "/api/mascotas/:id",
                    "parametros_url": {
                        "id": "integer — ID único de la mascota a actualizar."
                    },
                    "body_requerido": {
                        "nombre": "string — OPCIONAL.",
                        "especie": "string — 'Perro', 'Gato' u 'Otro'. OPCIONAL.",
                        "edad": "integer — OPCIONAL.",
                        "estadoSalud": "string — OPCIONAL.",
                        "fotoUrl": "string — OPCIONAL.",
                        "hogarId": "integer | null | '' — Para ASIGNAR enviar el ID del hogar (entero). Para DESASIGNAR enviar null o string vacío. Si no se envía este campo, el hogar actual no cambia."
                    },
                    "body_ejemplo_asignar_hogar": {
                        "hogarId": 2
                    },
                    "body_ejemplo_desasignar_hogar": {
                        "hogarId": null
                    },
                    "body_ejemplo_actualizar_datos": {
                        "nombre": "Maximiliano",
                        "edad": 4,
                        "estadoSalud": "Vacunado"
                    },
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": {
                            "id": 1,
                            "nombre": "Max",
                            "especie": "Perro",
                            "edad": 3,
                            "estadoSalud": "Saludable",
                            "estado": "En acogida",
                            "hogarId": 2,
                            "fotoUrl": null,
                            "createdAt": "2025-02-21T20:00:00.000Z",
                            "updatedAt": "2025-02-21T20:05:00.000Z"
                        }
                    },
                    "errores_posibles": {
                        "400": "El hogar ha alcanzado su capacidad máxima / Hogar no encontrado.",
                        "404": "Mascota no encontrada.",
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": true,
                    "evento_emitido": "mascota_actualizada"
                },
                {
                    "id": "eliminar_mascota",
                    "descripcion": "Elimina permanentemente una mascota del sistema.",
                    "metodo": "DELETE",
                    "url": "/api/mascotas/:id",
                    "parametros_url": {
                        "id": "integer — ID único de la mascota a eliminar."
                    },
                    "body_requerido": null,
                    "respuesta_exitosa": {
                        "status": 200,
                        "body_ejemplo": {
                            "msg": "Mascota eliminada correctamente"
                        }
                    },
                    "errores_posibles": {
                        "404": "Mascota no encontrada.",
                        "500": "Error del servidor."
                    },
                    "emite_evento_socket": true,
                    "evento_emitido": "mascota_eliminada",
                    "nota_socket": "El payload del socket solo contiene { id } no el objeto completo, ya que la mascota ya no existe."
                }
            ]
        },
        "hogares": {
            "descripcion": "Gestión de hogares temporales de acogida. tipoMascotaAceptada puede ser 'Perros', 'Gatos' o 'Ambos'. El campo 'ocupacionActual' es gestionado automáticamente por el servidor al asignar/desasignar mascotas.",
            "base_path": "/api/hogares",
