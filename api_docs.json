                        "capacidad": "integer — Número máximo de mascotas que puede alojar. REQUERIDO.",
                        "tipoMascotaAceptada": "string — 'Perros', 'Gatos' o 'Ambos'. REQUERIDO.",
                        "suministrosDisponibles": "string — Lista de suministros disponibles (ej: 'Camas, comida'). OPCIONAL."
